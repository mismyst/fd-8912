{
  "name": "founderz-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "backend",
    "libs/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm run dev -w @founderz/web",
    "dev:backend": "npm run dev -w @founderz/backend",
    "build": "npm run build:web && npm run build:backend",
    "build:web": "npm run build -w @founderz/web",
    "build:backend": "npm run build -w @founderz/backend",
    "lint": "npm run lint:web && npm run lint:backend",
    "lint:web": "npm run lint -w @founderz/web",
    "lint:backend": "npm run lint -w @founderz/backend",
    "typecheck": "npm run typecheck -w @founderz/web && npm run typecheck -w @founderz/backend",
    "check": "npm run lint && npm run typecheck"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
